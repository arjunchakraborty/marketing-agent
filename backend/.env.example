# Environment Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env files to version control!

# API Keys for authentication (comma-separated list)
# In production, use GCP Secret Manager instead of environment variables
API_KEYS=your-api-key-1,your-api-key-2

# Database Configuration
# Option A: PostgreSQL (legacy) or SQLite (local only)
# On Vercel: use a hosted DB (Neon, Supabase, etc.); SQLite in /tmp is ephemeral
DATABASE_URL=postgresql://user:password@localhost:5432/marketing_agent
# Option B: MongoDB (NoSQL) - set USE_MONGODB=true; use Atlas for Vercel
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=marketing_agent
USE_MONGODB=false

# CORS Configuration (Next.js dev runs on 2222 by default)
# For Vercel: add your frontend URL, e.g. https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:2222,https://your-frontend-domain.com

# LLM Configuration
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_MODEL=gpt-4o-mini
DEFAULT_LLM_PROVIDER=ollama

# Ollama Configuration (for local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Vector Database Configuration
# Option A: ChromaDB (local files)
VECTOR_DB_PATH=storage/vectors
ENABLE_VECTOR_SEARCH=true
# Option B: MongoDB Atlas Vector Search - set USE_ATLAS_VECTOR_SEARCH=true and create a vector index in Atlas
USE_ATLAS_VECTOR_SEARCH=false
MONGODB_VECTOR_INDEX_NAME=vector_index

# ComfyUI Configuration (for image generation)
COMFYUI_BASE_URL=http://localhost:8188

# Logging Configuration
LOG_LEVEL=INFO
LOG_EXPERIMENTS_DEBUG=true
